{
  "realm": "bandguy",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "loginWithEmailAllowed": true,
  "registrationEmailAsUsername": false,
  "duplicateEmailsAllowed": false,
  "verifyEmail": true,
  "rememberMe": true,
  "emailTheme": "keycloak",
  "loginTheme": "keycloak",
  "smtpServer": {
    "host": "bg-mailhog",
    "port": "1025",
    "from": "no-reply@local.dev",
    "fromDisplayName": "Dev Keycloak",
    "auth": false,
    "starttls": false,
    "ssl": false,
    "username": "",
    "password": ""
  },
  "authenticationFlows": [
    {
      "alias": "Magic Link Browser Flow",
      "description": "Passwordless flow for Band App",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-cookie",
          "requirement": "ALTERNATIVE",
          "priority": 10
        },
        {
          "authenticator": "auth-username-password-form",
          "requirement": "ALTERNATIVE",
          "priority": 20
        },
        {
          "authenticator": "ext-magic-form",
          "requirement": "ALTERNATIVE",
          "priority": 30,
          "authenticatorConfig": "magic-link-config"
        }
      ]
    },
    {
      "alias": "first broker login",
      "description": "Actions taken after first broker login with identity provider.",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": true,
      "authenticationExecutions": [
        {
          "authenticator": "idp-review-profile",
          "requirement": "REQUIRED",
          "priority": 10,
          "userSetupAllowed": false
        },
        {
          "authenticator": "idp-create-user-if-unique",
          "requirement": "ALTERNATIVE",
          "priority": 20,
          "userSetupAllowed": false
        },
        {
          "authenticator": "idp-auto-link-user",
          "requirement": "ALTERNATIVE",
          "priority": 30,
          "userSetupAllowed": false
        }
      ]
    }
  ],
  "authenticatorConfig": [
    {
      "alias": "magic-link-config",
      "config": {
        "force_create": "true",
        "update_profile": "false",
        "send_email": "true",
        "expiration_seconds": "3600"
      }
    }
  ],
  "browserFlow": "Magic Link Browser Flow",
  "registrationFlow": "registration",
